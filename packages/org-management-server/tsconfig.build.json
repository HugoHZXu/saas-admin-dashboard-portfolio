{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": false,
    "module": "CommonJS",
    "moduleResolution": "Node",
    "target": "ES2020",
    "noEmit": false,
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["**/*.test.*", "**/*.spec.*", "**/__tests__/**"]
}
