{
  "name": "admin-server",
  "version": "0.0.0",
  "private": true,
  "license": "MIT",
  "type": "commonjs",
  "main": "./dist/server.js",
  "types": "./dist/index.d.ts",
  "dependencies": {
    "@koa/cors": "5.0.0",
    "@prisma/client": "6.19.0",
    "graphql": "16.14.0",
    "graphql-http": "1.22.4",
    "koa": "3.2.1",
    "koa-mount": "4.2.0"
  },
  "devDependencies": {
    "@types/jest": "30.0.0",
    "@types/koa": "3.0.3",
    "@types/koa-mount": "4.0.5",
    "@types/koa__cors": "5.0.1",
    "@types/node": "^22.19.19",
    "jest": "30.4.2",
    "prisma": "6.19.0",
    "ts-jest": "29.4.11",
    "tsx": "4.22.3"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.{ts,tsx}\" \"prisma/**/*.ts\"",
    "typecheck": "prisma generate && tsc -p tsconfig.json --noEmit",
    "test": "prisma generate && jest --config jest.config.cjs",
    "prisma:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:studio": "DATABASE_URL=file:./dev.db prisma studio",
    "db:seed": "tsx prisma/seed.ts",
    "db:reset": "tsx prisma/reset.ts",
    "db:generate-public-users": "tsx prisma/generatePublicUsers.ts"
  }
}
