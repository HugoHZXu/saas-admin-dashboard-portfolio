{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "src",
    "outDir": "dist",
    "declaration": true,
    "declarationMap": false,
    "emitDeclarationOnly": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "target": "ES2020",
    "noEmit": false,
    "sourceMap": true
  },
  "include": ["src"],
  "exclude": ["**/*.test.*", "**/*.stories.*", "**/__tests__/**", "src/utils/testUtils.tsx"]
}
