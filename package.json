{
  "name": "ui-demo-monorepo",
  "private": true,
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.34.1 <11"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "storybook": "pnpm --filter storybook-demo run storybook",
    "dev:org-management": "pnpm --filter org-management run dev",
    "dev:org-management-server": "pnpm --filter org-management-server run dev",
    "build-storybook": "pnpm --filter storybook-demo run build-storybook",
    "typecheck": "pnpm -r run typecheck",
    "lint": "pnpm -r run lint",
    "format": "prettier \"**/*.{ts,tsx,js,jsx,json,md}\" --write",
    "build-hugo-ui": "pnpm --filter hugo-ui run build",
    "build-hugo-ui-shadcn": "pnpm --filter hugo-ui-shadcn run build",
    "build-org-management-server": "pnpm --filter org-management-server run build",
    "build-org-management": "pnpm --filter org-management run build",
    "build:all": "pnpm run build-hugo-ui && pnpm run build-hugo-ui-shadcn && pnpm run build-org-management-server && pnpm run build-org-management && pnpm run build-storybook",
    "publish-hugo-ui": "pnpm --filter hugo-ui publish",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "test": "pnpm --filter hugo-ui run test",
    "test-hugo-ui-shadcn": "pnpm --filter hugo-ui-shadcn run test",
    "test-org-management-server": "pnpm --filter org-management-server run test",
    "test:all": "pnpm run test && pnpm run test-hugo-ui-shadcn && pnpm run test-org-management-server",
    "test:watch": "pnpm --filter hugo-ui run test:watch",
    "test:coverage": "pnpm --filter hugo-ui run test:coverage",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test:all && pnpm run build:all"
  },
  "devDependencies": {
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
