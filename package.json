{
  "name": "hugo-saas-console",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=26.4.0",
    "pnpm": ">=11.7.0 <12"
  },
  "scripts": {
    "dev:org-management": "pnpm --filter org-management run dev",
    "dev:user-management": "pnpm --filter user-management run dev",
    "dev:admin-console": "pnpm --filter admin-console run dev",
    "setup:local-hugo-ui": "node scripts/setup-local-hugo-ui.mjs",
    "verify:hugo-ui": "node scripts/verify-hugo-ui-mode.mjs",
    "typecheck": "pnpm --filter admin-shared --filter admin-console --filter org-management --filter user-management run typecheck",
    "lint": "pnpm --filter admin-console --filter org-management --filter user-management run lint",
    "format": "prettier \"**/*.{ts,tsx,js,jsx,json,md}\" --write",
    "build-admin-shared": "pnpm --filter admin-shared run build",
    "build-admin-console": "pnpm --filter admin-console run build",
    "build-org-management": "pnpm --filter org-management run build",
    "build-user-management": "pnpm --filter user-management run build",
    "build:all": "pnpm run verify:hugo-ui && pnpm run build-admin-shared && pnpm run build-org-management && pnpm run build-user-management && pnpm run build-admin-console",
    "test": "pnpm run test:all",
    "test:frontend": "pnpm run verify:hugo-ui && pnpm --filter admin-shared --filter admin-console --filter org-management --filter user-management run test",
    "test:all": "pnpm run test:frontend",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test:all && pnpm run build:all"
  },
  "devDependencies": {
    "@emotion/cache": "11.14.0",
    "@emotion/react": "11.14.0",
    "@emotion/styled": "11.14.1",
    "@eslint/js": "^10.0.1",
    "@fontsource/noto-sans": "5.2.10",
    "@fontsource/noto-sans-arabic": "5.2.10",
    "@fontsource/noto-sans-jp": "5.2.9",
    "@fontsource/noto-sans-thai": "5.2.8",
    "@mui/icons-material": "9.0.1",
    "@mui/material": "9.0.1",
    "@mui/system": "9.0.1",
    "@mui/utils": "9.0.1",
    "@rolldown/plugin-babel": "^0.2.3",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "@vitejs/plugin-react": "6.0.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "classnames": "2.5.1",
    "css-mediaquery": "0.1.2",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "jsdom": "^29.1.1",
    "lodash": "4.18.1",
    "moment": "2.30.1",
    "prettier": "^3.8.3",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "react-intl": "10.1.9",
    "stylis": "4.4.0",
    "stylis-plugin-rtl": "2.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
