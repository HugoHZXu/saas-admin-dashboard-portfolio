{
  "name": "ui-demo-monorepo",
  "private": true,
  "engines": {
    "node": ">=22.12.0",
    "npm": ">=10.9.0"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "storybook": "npm -w packages/storybook-demo run storybook",
    "dev:org-management": "npm -w packages/org-management run dev",
    "dev:org-management-server": "npm -w packages/org-management-server run dev",
    "build-storybook": "npm -w packages/storybook-demo run build-storybook",
    "typecheck": "npm -ws run typecheck",
    "lint": "npm -ws run lint",
    "format": "prettier \"**/*.{ts,tsx,js,jsx,json,md}\" --write",
    "build-hugo-ui": "npm -w packages/hugo-ui run build",
    "build-hugo-ui-shadcn": "npm -w packages/hugo-ui-shadcn run build",
    "build-org-management-server": "npm -w packages/org-management-server run build",
    "build-org-management": "npm -w packages/org-management run build",
    "build:all": "npm run build-hugo-ui && npm run build-hugo-ui-shadcn && npm run build-org-management-server && npm run build-org-management && npm run build-storybook",
    "publish-hugo-ui": "npm -w packages/hugo-ui publish",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:publish": "changeset publish",
    "test": "npm -w packages/hugo-ui run test",
    "test-hugo-ui-shadcn": "npm -w packages/hugo-ui-shadcn run test",
    "test-org-management-server": "npm -w packages/org-management-server run test",
    "test:all": "npm run test && npm run test-hugo-ui-shadcn && npm run test-org-management-server",
    "test:watch": "npm -w packages/hugo-ui run test:watch",
    "test:coverage": "npm -w packages/hugo-ui run test:coverage",
    "verify": "npm run lint && npm run typecheck && npm run test:all && npm run build:all"
  },
  "devDependencies": {
    "@changesets/changelog-git": "^0.2.1",
    "@changesets/cli": "^2.31.0",
    "@eslint/js": "^10.0.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
