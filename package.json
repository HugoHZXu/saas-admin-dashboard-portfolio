{
  "name": "saas-admin-dashboard-portfolio",
  "private": true,
  "license": "MIT",
  "packageManager": "pnpm@10.34.1",
  "engines": {
    "node": ">=22.12.0",
    "pnpm": ">=10.34.1 <11"
  },
  "scripts": {
    "dev:org-management": "pnpm --filter org-management run dev",
    "dev:user-management": "pnpm --filter user-management run dev",
    "dev:admin-console": "pnpm --filter admin-console run dev",
    "dev:admin-server": "pnpm --filter admin-server run dev",
    "setup:local-hugo-ui": "node scripts/setup-local-hugo-ui.mjs",
    "typecheck": "pnpm --filter admin-shared --filter admin-console --filter admin-server --filter org-management --filter user-management run typecheck",
    "lint": "pnpm --filter admin-console --filter admin-server --filter org-management --filter user-management run lint",
    "format": "prettier \"**/*.{ts,tsx,js,jsx,json,md}\" --write",
    "build-admin-shared": "pnpm --filter admin-shared run build",
    "build-admin-console": "pnpm --filter admin-console run build",
    "build-admin-server": "pnpm --filter admin-server run build",
    "build-org-management": "pnpm --filter org-management run build",
    "build-user-management": "pnpm --filter user-management run build",
    "build:all": "pnpm run build-admin-shared && pnpm run build-admin-server && pnpm run build-org-management && pnpm run build-user-management && pnpm run build-admin-console",
    "db:reset-admin": "pnpm --filter admin-server run db:reset",
    "db:studio-admin": "pnpm --filter admin-server run db:studio",
    "db:generate-public-users": "pnpm --filter admin-server run db:generate-public-users",
    "test": "pnpm run test-admin-server",
    "test-admin-server": "pnpm --filter admin-server run test",
    "test:all": "pnpm run test-admin-server",
    "verify": "pnpm run lint && pnpm run typecheck && pnpm run test:all && pnpm run build:all"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@fontsource/noto-sans": "5.2.10",
    "@fontsource/noto-sans-arabic": "5.2.10",
    "@fontsource/noto-sans-jp": "5.2.9",
    "@fontsource/noto-sans-thai": "5.2.8",
    "@rolldown/plugin-babel": "^0.2.3",
    "@types/node": "^22.19.19",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.60.0",
    "@typescript-eslint/parser": "^8.60.0",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-react-hooks": "^7.1.1",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  }
}
